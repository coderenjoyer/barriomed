{
  "expo": {
    "name": "barriomed",
    "slug": "barriomed",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/nobg.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.coderenjoyer.barriomed"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/nobg.png",
          "color": "#0D9488",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "BarrioMed"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/nobg.png"
    },
    "extra": {
      "eas": {
        "projectId": "86a911ed-56bf-4ef1-95c6-d836c1c8e46a"
      }
    }
  }
}